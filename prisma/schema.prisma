// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:/app/data/dev.db"
}

enum JobStatus {
  PENDING_APPROVAL
  APPROVED
  QUEUED // Added for when approved but printer not ready
  PRINTING
  COMPLETED
  FAILED
  REJECTED
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String?
  files     File[]
  submittedPrintJobs PrintJob[] @relation("SubmittedJobs")
  approvedPrintJobs  PrintJob[] @relation("ApprovedJobs")
  uploadedMachineProfiles  MachineProfile[]  @relation("UploadedMachineProfiles")
  uploadedFilamentProfiles FilamentProfile[] @relation("UploadedFilamentProfiles")
  uploadedSlicingProfiles  SlicingProfile[]  @relation("UploadedSlicingProfiles")
  submittedSliceJobs     SliceJob[]      @relation("SubmittedSliceJobs")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  isEnabled Boolean @default(true)

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])
}

model Printer {
  id                 String     @id @default(cuid())
  name               String
  type               String
  apiUrl             String
  apiKey             String?
  serialNumber       String?
  status             String     @default("active")
  operationalStatus  String     @default("idle")
  lastSeen           DateTime   @default(now())
  printStartTime     DateTime?
  printTimeElapsed   Float?
  printTimeRemaining Float?
  webcamUrl          String?
  hlsUrl             String?
  webrtcUrl          String?
  cameraStreamMode   String     @default("hls")
  cameraPathName     String?    @unique
  onvifHost          String?
  onvifPort          Int?
  onvifUsername      String?
  onvifPassword      String?
  printImageUrl      String?
  printJobName       String?
  bedTemp            Float?
  toolTemp           Float?
  currentJobFilename String?
  printJobs          PrintJob[]
  sliceJobs          SliceJob[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  groupId            String?
  group              Group?     @relation(fields: [groupId], references: [id])
  machineProfileId   String?
  machineProfile     MachineProfile? @relation(fields: [machineProfileId], references: [id])
}

model PrintJob {
  id          String    @id @default(cuid())
  name        String
  status      JobStatus @default(PENDING_APPROVAL)
  createdAt   DateTime  @default(now())
  submittedAt DateTime  @default(now())
  approvedAt  DateTime?
  queuedAt    DateTime?
  updatedAt   DateTime  @updatedAt
  fileId      String
  file        File      @relation(fields: [fileId], references: [id])
  printerId   String
  printer     Printer   @relation(fields: [printerId], references: [id])
  submittedByUserId String?
  submittedByUser User?    @relation("SubmittedJobs", fields: [submittedByUserId], references: [id])
  approvedByUserId String?
  approvedByUser User?     @relation("ApprovedJobs", fields: [approvedByUserId], references: [id])
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  rejectedAt  DateTime?
  errorMessage String?
  notes       String?

  @@index([status])
  @@index([submittedByUserId])
  @@index([printerId])
}

model File {
  id         String     @id @default(cuid())
  name       String
  path       String
  size       Int
  type       String
  previewUrl String?
  uploadedAt DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  uploadedBy String
  user       User       @relation(fields: [uploadedBy], references: [id])
  groupId    String?
  group      Group?     @relation(fields: [groupId], references: [id])
  printJobs  PrintJob[]
  sliceJobsAsSource SliceJob[] @relation("SliceJobSource")
  sliceJobsAsResult SliceJob[] @relation("SliceJobResult")
}

model MachineProfile {
  id                     String           @id @default(cuid())
  name                   String           @unique
  description            String?
  machineJson            String
  filename               String
  uploadedByUserId       String?
  uploadedBy             User?            @relation("UploadedMachineProfiles", fields: [uploadedByUserId], references: [id])
  printers               Printer[]
  sliceJobs              SliceJob[]
  // Empty list = unrestricted (any Slicing Profile in the library may be
  // used with this machine); once curated, only these may be selected.
  allowedSlicingProfiles SlicingProfile[] @relation("MachineAllowedSlicingProfiles")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model FilamentProfile {
  id               String     @id @default(cuid())
  name             String     @unique
  description      String?
  filamentJson     String
  filename         String
  uploadedByUserId String?
  uploadedBy       User?      @relation("UploadedFilamentProfiles", fields: [uploadedByUserId], references: [id])
  sliceJobs        SliceJob[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model SlicingProfile {
  id                String           @id @default(cuid())
  name              String           @unique
  description       String?
  // OrcaSlicer's own "process" profile JSON, verbatim - an internal detail,
  // not renamed alongside the model despite the user-facing name change.
  processJson       String
  filename          String
  uploadedByUserId  String?
  uploadedBy        User?            @relation("UploadedSlicingProfiles", fields: [uploadedByUserId], references: [id])
  sliceJobs         SliceJob[]
  allowedForMachines MachineProfile[] @relation("MachineAllowedSlicingProfiles")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

enum SliceJobStatus {
  QUEUED
  SLICING
  COMPLETED
  FAILED
}

model SliceJob {
  id                  String           @id @default(cuid())
  status              SliceJobStatus   @default(QUEUED)
  sourceFileId        String
  sourceFile          File             @relation("SliceJobSource", fields: [sourceFileId], references: [id])
  printerId           String
  printer             Printer          @relation(fields: [printerId], references: [id])
  machineProfileId    String?
  machineProfile      MachineProfile?  @relation(fields: [machineProfileId], references: [id], onDelete: SetNull)
  filamentProfileId   String?
  filamentProfile     FilamentProfile? @relation(fields: [filamentProfileId], references: [id], onDelete: SetNull)
  slicingProfileId    String?
  slicingProfile      SlicingProfile?  @relation(fields: [slicingProfileId], references: [id], onDelete: SetNull)
  customOverridesJson String?
  resultFileId        String?
  resultFile          File?            @relation("SliceJobResult", fields: [resultFileId], references: [id])
  submittedByUserId   String?
  submittedByUser     User?            @relation("SubmittedSliceJobs", fields: [submittedByUserId], references: [id])
  errorMessage        String?
  createdAt           DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  startedAt           DateTime?
  completedAt         DateTime?

  @@index([status])
  @@index([sourceFileId])
  @@index([printerId])
}

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  printers    Printer[]
  files       File[]
}

model Role {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  allowedPages String   @default("[]") // JSON array of allowed page identifiers
  allowedActions String @default("[]") // JSON array of allowed action identifiers
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[] // Relation to User model
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
